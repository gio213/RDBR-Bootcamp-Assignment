    "/enrollments": {
      "get": {
        "tags": [
          "Enrollments"
        ],
        "summary": "List the authenticated user's enrollments",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Enrollments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Enrollment"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      },
      "post": {
        "tags": [
          "Enrollments"
        ],
        "summary": "Enroll in a course",
        "description": "Requires a complete profile. Returns 409 with `conflicts` array if a schedule conflict is detected. Re-submit with `force: true` to override.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "courseId",
                  "courseScheduleId"
                ],
                "properties": {
                  "courseId": {
                    "type": "integer",
                    "example": 1
                  },
                  "courseScheduleId": {
                    "type": "integer",
                    "example": 5
                  },
                  "force": {
                    "type": "boolean",
                    "default": false,
                    "description": "Override schedule conflicts"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Enrolled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Enrollment"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "409": {
            "description": "Conflict (schedule conflict or duplicate enrollment)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictError"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
